      <bpmn2:scriptTask id="_CC81983F-CF17-4FE3-9045-A69CB140F20F" name="Report SLA Breach Immediately" scriptFormat="http://www.java.com/java">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Report SLA Breach Immediately]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>_549183A8-99BD-4111-AB2D-FE4E04CAF67B</bpmn2:incoming>
        <bpmn2:outgoing>_1D19A6F9-6823-4434-A0F4-BC4AD18678D8</bpmn2:outgoing>
        <bpmn2:script><![CDATA[// ticketId'yi güvenlice çekiyoruz
Object tidObj = kcontext.getVariable("ticketId");
long safeTicketId = (tidObj != null) ? ((Number) tidObj).longValue() : 0L;

Object pausedObj = kcontext.getVariable("slaPaused");
boolean isPaused = (pausedObj instanceof Boolean) ? (Boolean) pausedObj : false;

System.out.println("Dinamik SLA Hesabi: Kalan sure negatif. SLA_PAUSED durumu: " + isPaused + ". Ticket ID: " + safeTicketId);

if (isPaused) {
    System.out.println("SLA paused=true olduğu için anlık sla-breach webhook gönderilmiyor. Ticket ID: " + safeTicketId);
} else {
    try {
        java.net.URL url = new java.net.URL("http://host.docker.internal:8080/api/webhook/jbpm/sla-breach");
        java.net.HttpURLConnection con = (java.net.HttpURLConnection) url.openConnection();

        con.setRequestMethod("POST");
        con.setRequestProperty("Content-Type", "application/json; charset=utf-8");
        con.setRequestProperty("X-Webhook-Secret", "destrova-webhook-dev-secret");
        con.setRequestProperty("X-Idempotency-Key", java.util.UUID.randomUUID().toString());
        con.setDoOutput(true);

        String jsonInputString = "{\"ticketId\": " + safeTicketId + "}";

        try (java.io.OutputStream os = con.getOutputStream()) {
            byte[] input = jsonInputString.getBytes(java.nio.charset.StandardCharsets.UTF_8);
            os.write(input, 0, input.length);
        }

        int responseCode = con.getResponseCode();
        System.out.println("Anlik SLA Breach webhook basariyla cagrildi. HTTP Kodu: " + responseCode);

    } catch (Exception e) {
        System.out.println("Anlik SLA Breach webhook cagrisinda hata: " + e.getMessage());
    }
}]]></bpmn2:script>
      </bpmn2:scriptTask>
