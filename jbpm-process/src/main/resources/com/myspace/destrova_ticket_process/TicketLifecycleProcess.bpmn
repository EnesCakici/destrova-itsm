      <bpmn2:script><![CDATA[kcontext.setVariable("previousStatus", kcontext.getVariable("currentStatus"));

kcontext.setVariable("currentStatus", "IN_PROGRESS");
kcontext.setVariable("slaPaused", false);

String resStr = (String) kcontext.getVariable("resolvedAt");
if (resStr != null) {
    java.time.Instant start = java.time.Instant.parse(resStr);
    java.time.Instant now = java.time.Instant.now();
    long diff = java.time.Duration.between(start, now).toMillis();

    Object totalObj = kcontext.getVariable("totalPausedDuration");
    long total = (totalObj != null) ? ((Number) totalObj).longValue() : 0L;

    kcontext.setVariable("totalPausedDuration", total + diff);
}

String WEBHOOK_BASE = "http://host.docker.internal:8080/api/webhook/jbpm";
String WEBHOOK_SECRET = "destrova-webhook-dev-secret";
String CONTAINER_ID = "destrova-ticket-process_1.0.0-SNAPSHOT";
String PROCESS_ID = "destrova-ticket-process.TicketLifecycleProcess";

java.util.function.Function<Object, String> jsonStr = (Object o) -> {
    if (o == null) return "null";
    String s = String.valueOf(o);
    return "\"" + s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r") + "\"";
};

java.util.function.Function<Object, String> jsonBool = (Object o) -> {
    if (o == null) return "false";
    if (o instanceof Boolean) return ((Boolean) o) ? "true" : "false";
    return Boolean.parseBoolean(String.valueOf(o)) ? "true" : "false";
};

java.util.function.BiFunction<String, String, Integer> postWebhook = (String path, String jsonBody) -> {
    try {
        java.net.URL url = new java.net.URL(WEBHOOK_BASE + path);
        java.net.HttpURLConnection con = (java.net.HttpURLConnection) url.openConnection();

        con.setRequestMethod("POST");
        con.setRequestProperty("Content-Type", "application/json; charset=utf-8");
        con.setRequestProperty("X-Webhook-Secret", WEBHOOK_SECRET);
        con.setRequestProperty("X-Idempotency-Key", java.util.UUID.randomUUID().toString());
        con.setDoOutput(true);

        byte[] bytes = jsonBody.getBytes(java.nio.charset.StandardCharsets.UTF_8);
        con.setFixedLengthStreamingMode(bytes.length);

        try (java.io.OutputStream os = con.getOutputStream()) {
            os.write(bytes);
        }

        int code = con.getResponseCode();
        System.out.println("Webhook POST " + path + " -> HTTP " + code);
        return code;
    } catch (Exception e) {
        System.out.println("Webhook error " + path + ": " + e.getMessage());
        return -1;
    }
};

Object ticketIdObj = kcontext.getVariable("ticketId");
long ticketId = (ticketIdObj != null) ? ((Number) ticketIdObj).longValue() : 0L;

long processInstanceId = kcontext.getProcessInstance().getId();
String correlationKey = String.valueOf(ticketId);

String statusEventId = java.util.UUID.randomUUID().toString();
String statusOccurredAt = java.time.Instant.now().toString();

Object prevObj = kcontext.getVariable("previousStatus");
String previousStatus = (prevObj != null) ? String.valueOf(prevObj) : "NEW";

Object currObj = kcontext.getVariable("currentStatus");
String newStatus = (currObj != null) ? String.valueOf(currObj) : previousStatus;

Object statusSlaPausedObj = kcontext.getVariable("slaPaused");
boolean statusSlaPaused = (statusSlaPausedObj instanceof Boolean)
    ? (Boolean) statusSlaPausedObj
    : Boolean.parseBoolean(String.valueOf(statusSlaPausedObj));

Object closedAtObj = kcontext.getVariable("closedAt");
String closedAtJson = (closedAtObj != null) ? jsonStr.apply(String.valueOf(closedAtObj)) : "null";

Object closureReasonObj = kcontext.getVariable("closureReason");
String closureReasonJson = (closureReasonObj != null) ? jsonStr.apply(String.valueOf(closureReasonObj)) : "null";

Object rejectionNoteObj = kcontext.getVariable("customerRejectionNote");
String rejectionNoteJson = (rejectionNoteObj != null) ? jsonStr.apply(String.valueOf(rejectionNoteObj)) : "null";

String statusSignalName = "CUSTOMER_REJECTED";
String statusNodeId = "ScriptTask_CustomerRejected_Status_01";
String statusNodeName = "Rejected";

String statusJson = "{"
    + "\"eventId\":" + jsonStr.apply(statusEventId) + ","
    + "\"eventType\":\"status-changed\","
    + "\"occurredAt\":" + jsonStr.apply(statusOccurredAt) + ","
    + "\"ticketId\":" + ticketId + ","
    + "\"processInstanceId\":" + processInstanceId + ","
    + "\"correlationKey\":" + jsonStr.apply(correlationKey) + ","
    + "\"processId\":" + jsonStr.apply(PROCESS_ID) + ","
    + "\"containerId\":" + jsonStr.apply(CONTAINER_ID) + ","
    + "\"triggeredBy\":{"
        + "\"signal\":" + jsonStr.apply(statusSignalName) + ","
        + "\"nodeId\":" + jsonStr.apply(statusNodeId) + ","
        + "\"nodeName\":" + jsonStr.apply(statusNodeName)
    + "},"
    + "\"payload\":{"
        + "\"previousStatus\":" + jsonStr.apply(previousStatus) + ","
        + "\"newStatus\":" + jsonStr.apply(newStatus) + ","
        + "\"slaPaused\":" + jsonBool.apply(statusSlaPaused) + ","
        + "\"closedAt\":" + closedAtJson + ","
        + "\"closureReason\":" + closureReasonJson + ","
        + "\"customerRejectionNote\":" + rejectionNoteJson
    + "}"
    + "}";

postWebhook.apply("/status-changed", statusJson);

String slaEventId = java.util.UUID.randomUUID().toString();
String slaOccurredAt = java.time.Instant.now().toString();

Object slaDeadlineObj = kcontext.getVariable("slaDeadline");
String slaDueDate = (slaDeadlineObj != null) ? String.valueOf(slaDeadlineObj) : null;

Object slaStartedAtObj = kcontext.getVariable("slaStartedAt");
String slaStartedAt = (slaStartedAtObj != null) ? String.valueOf(slaStartedAtObj) : null;

Object priorityObj = kcontext.getVariable("priority");
String priority = (priorityObj != null) ? String.valueOf(priorityObj) : "MEDIUM";

Object totalPausedObj2 = kcontext.getVariable("totalPausedDuration");
long totalPausedDurationMs = (totalPausedObj2 != null) ? ((Number) totalPausedObj2).longValue() : 0L;

Object slaPausedObj2 = kcontext.getVariable("slaPaused");
boolean slaPausedForSlaEvent = (slaPausedObj2 instanceof Boolean) ? (Boolean) slaPausedObj2 : false;

String remainingDurationIso = "PT24H";
if ("HIGH".equals(priority)) {
    remainingDurationIso = "PT4H";
} else if ("LOW".equals(priority)) {
    remainingDurationIso = "PT48H";
}

String reason = "RESUMED_FROM_RESOLVED";

Object prevPriorityObj = kcontext.getVariable("previousPriority");
String previousPriorityJson = (prevPriorityObj != null) ? jsonStr.apply(String.valueOf(prevPriorityObj)) : "null";

String slaSignalName = "CUSTOMER_REJECTED";
String slaNodeId = "ScriptTask_CustomerRejected_Sla_01";
String slaNodeName = "Notify sla-updated after customer rejected";

String slaJson = "{"
    + "\"eventId\":" + jsonStr.apply(slaEventId) + ","
    + "\"eventType\":\"sla-updated\","
    + "\"occurredAt\":" + jsonStr.apply(slaOccurredAt) + ","
    + "\"ticketId\":" + ticketId + ","
    + "\"processInstanceId\":" + processInstanceId + ","
    + "\"correlationKey\":" + jsonStr.apply(correlationKey) + ","
    + "\"processId\":" + jsonStr.apply(PROCESS_ID) + ","
    + "\"containerId\":" + jsonStr.apply(CONTAINER_ID) + ","
    + "\"triggeredBy\":{"
        + "\"signal\":" + jsonStr.apply(slaSignalName) + ","
        + "\"nodeId\":" + jsonStr.apply(slaNodeId) + ","
        + "\"nodeName\":" + jsonStr.apply(slaNodeName)
    + "},"
    + "\"payload\":{"
        + "\"slaDueDate\":" + jsonStr.apply(slaDueDate) + ","
        + "\"slaStartedAt\":" + jsonStr.apply(slaStartedAt) + ","
        + "\"priority\":" + jsonStr.apply(priority) + ","
        + "\"slaPaused\":" + jsonBool.apply(slaPausedForSlaEvent) + ","
        + "\"totalPausedDurationMs\":" + totalPausedDurationMs + ","
        + "\"remainingDurationIso\":" + jsonStr.apply(remainingDurationIso) + ","
        + "\"reason\":" + jsonStr.apply(reason) + ","
        + "\"previousPriority\":" + previousPriorityJson
    + "}"
    + "}";

postWebhook.apply("/sla-updated", slaJson);]]></bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="_1F53D5DB-5D8B-4DC5-BBB1-26104BD6D45F" name="Initialize SLA Projection" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Initialize SLA Projection]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_451285B3-A15E-4F90-B916-F94A6CDA6EBB</bpmn2:incoming>
      <bpmn2:outgoing>_39CA746A-57D4-4614-BF38-907CF3D68B91</bpmn2:outgoing>
      <bpmn2:script><![CDATA[if (kcontext.getVariable("slaStartedAt") == null) {
    kcontext.setVariable("slaStartedAt", java.time.Instant.now().toString());
}

if (kcontext.getVariable("currentStatus") == null) {
    kcontext.setVariable("currentStatus", "NEW");
}

if (kcontext.getVariable("priority") == null) {
    kcontext.setVariable("priority", "MEDIUM");
}

if (kcontext.getVariable("slaPaused") == null) {
    kcontext.setVariable("slaPaused", false);
}

String WEBHOOK_BASE = "http://host.docker.internal:8080/api/webhook/jbpm";
String WEBHOOK_SECRET = "destrova-webhook-dev-secret";
String CONTAINER_ID = "destrova-ticket-process_1.0.0-SNAPSHOT";
String PROCESS_ID = "destrova-ticket-process.TicketLifecycleProcess";

java.util.function.Function<Object, String> jsonStr = (Object o) -> {
    if (o == null) return "null";
    String s = String.valueOf(o);
    return "\"" + s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r") + "\"";
};

java.util.function.Function<Object, String> jsonBool = (Object o) -> {
    if (o == null) return "false";
    if (o instanceof Boolean) return ((Boolean) o) ? "true" : "false";
    return Boolean.parseBoolean(String.valueOf(o)) ? "true" : "false";
};

java.util.function.BiFunction<String, String, Integer> postWebhook = (String path, String jsonBody) -> {
    try {
        java.net.URL url = new java.net.URL(WEBHOOK_BASE + path);
        java.net.HttpURLConnection con = (java.net.HttpURLConnection) url.openConnection();

        con.setRequestMethod("POST");
        con.setRequestProperty("Content-Type", "application/json; charset=utf-8");
        con.setRequestProperty("X-Webhook-Secret", WEBHOOK_SECRET);
        con.setRequestProperty("X-Idempotency-Key", java.util.UUID.randomUUID().toString());
        con.setDoOutput(true);

        byte[] bytes = jsonBody.getBytes(java.nio.charset.StandardCharsets.UTF_8);
        con.setFixedLengthStreamingMode(bytes.length);

        try (java.io.OutputStream os = con.getOutputStream()) {
            os.write(bytes);
        }

        int code = con.getResponseCode();
        System.out.println("Webhook POST " + path + " -> HTTP " + code);
        return code;
    } catch (Exception e) {
        System.out.println("Webhook error " + path + ": " + e.getMessage());
        return -1;
    }
};

Object ticketIdObj = kcontext.getVariable("ticketId");
long ticketId = (ticketIdObj != null) ? ((Number) ticketIdObj).longValue() : 0L;

long processInstanceId = kcontext.getProcessInstance().getId();
String correlationKey = String.valueOf(ticketId);
String eventId = java.util.UUID.randomUUID().toString();
String occurredAt = java.time.Instant.now().toString();

Object slaDeadlineObj = kcontext.getVariable("slaDeadline");
String slaDueDate = (slaDeadlineObj != null) ? String.valueOf(slaDeadlineObj) : null;

Object slaStartedAtObj = kcontext.getVariable("slaStartedAt");
String slaStartedAt = (slaStartedAtObj != null) ? String.valueOf(slaStartedAtObj) : null;

Object priorityObj = kcontext.getVariable("priority");
String priority = (priorityObj != null) ? String.valueOf(priorityObj) : "MEDIUM";

Object totalPausedObj = kcontext.getVariable("totalPausedDuration");
long totalPausedDurationMs = (totalPausedObj != null) ? ((Number) totalPausedObj).longValue() : 0L;

Object slaPausedObj = kcontext.getVariable("slaPaused");
boolean slaPaused = (slaPausedObj instanceof Boolean) ? (Boolean) slaPausedObj : false;

String remainingDurationIso = "PT24H";
if ("HIGH".equals(priority)) {
    remainingDurationIso = "PT4H";
} else if ("LOW".equals(priority)) {
    remainingDurationIso = "PT48H";
}

String reason = "PROCESS_STARTED";

Object prevPriorityObj = kcontext.getVariable("previousPriority");
String previousPriorityJson = (prevPriorityObj != null) ? jsonStr.apply(String.valueOf(prevPriorityObj)) : "null";

String signalName = "PROCESS_STARTED";
String nodeId = "ScriptTask_ProcessStarted_Sla_01";
String nodeName = "Initialize SLA Projection";

String json = "{"
    + "\"eventId\":" + jsonStr.apply(eventId) + ","
    + "\"eventType\":\"sla-updated\","
    + "\"occurredAt\":" + jsonStr.apply(occurredAt) + ","
    + "\"ticketId\":" + ticketId + ","
    + "\"processInstanceId\":" + processInstanceId + ","
    + "\"correlationKey\":" + jsonStr.apply(correlationKey) + ","
    + "\"processId\":" + jsonStr.apply(PROCESS_ID) + ","
    + "\"containerId\":" + jsonStr.apply(CONTAINER_ID) + ","
    + "\"triggeredBy\":{"
        + "\"signal\":" + jsonStr.apply(signalName) + ","
        + "\"nodeId\":" + jsonStr.apply(nodeId) + ","
        + "\"nodeName\":" + jsonStr.apply(nodeName)
    + "},"
    + "\"payload\":{"
        + "\"slaDueDate\":" + jsonStr.apply(slaDueDate) + ","
        + "\"slaStartedAt\":" + jsonStr.apply(slaStartedAt) + ","
        + "\"priority\":" + jsonStr.apply(priority) + ","
        + "\"slaPaused\":" + jsonBool.apply(slaPaused) + ","
        + "\"totalPausedDurationMs\":" + totalPausedDurationMs + ","
        + "\"remainingDurationIso\":" + jsonStr.apply(remainingDurationIso) + ","
        + "\"reason\":" + jsonStr.apply(reason) + ","
        + "\"previousPriority\":" + previousPriorityJson
    + "}"
    + "}";

postWebhook.apply("/sla-updated", json);]]></bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="_8A123DA2-C282-42C2-838B-011F138C3121" name="Report SLA Violation" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Report SLA Violation]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_092F479B-FA49-489F-9F87-F241505CE6E7</bpmn2:incoming>
      <bpmn2:outgoing>_E3E67F9E-D54D-4D8B-951A-AD603EF55C8B</bpmn2:outgoing>
      <bpmn2:script><![CDATA[// ticketId'yi Integer gelse bile patlamayacak şekilde güvenlice çekiyoruz
Object tidObj = kcontext.getVariable("ticketId");
long safeTicketId = (tidObj != null) ? ((Number) tidObj).longValue() : 0L;

Object pausedObj = kcontext.getVariable("slaPaused");
boolean isPaused = (pausedObj instanceof Boolean) ? (Boolean) pausedObj : false;

System.out.println("SLA Timer doldu. SLA_PAUSED durumu: " + isPaused + ". Ticket ID: " + safeTicketId);

if (isPaused) {
    System.out.println("SLA paused=true olduğu için sla-breach webhook gönderilmiyor. Ticket ID: " + safeTicketId);
} else {
    try {
        java.net.URL url = new java.net.URL("http://host.docker.internal:8080/api/webhook/jbpm/sla-breach");
        java.net.HttpURLConnection con = (java.net.HttpURLConnection) url.openConnection();

        con.setRequestMethod("POST");
        con.setRequestProperty("Content-Type", "application/json; charset=utf-8");
        con.setRequestProperty("X-Webhook-Secret", "destrova-webhook-dev-secret");
        con.setRequestProperty("X-Idempotency-Key", java.util.UUID.randomUUID().toString());
        con.setDoOutput(true);

        String jsonInputString = "{\"ticketId\": " + safeTicketId + "}";

        try (java.io.OutputStream os = con.getOutputStream()) {
            byte[] input = jsonInputString.getBytes(java.nio.charset.StandardCharsets.UTF_8);
            os.write(input, 0, input.length);
        }

        int responseCode = con.getResponseCode();
        System.out.println("SLA breach webhook başarıyla çağrıldı. HTTP Kodu: " + responseCode);

    } catch (Exception e) {
        System.out.println("SLA breach webhook çağrısında hata: " + e.getMessage());
    }
}]]></bpmn2:script>
    </bpmn2:scriptTask>
