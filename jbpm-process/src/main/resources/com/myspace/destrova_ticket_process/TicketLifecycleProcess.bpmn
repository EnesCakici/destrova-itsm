    <bpmn2:scriptTask id="_EA88FF9A-05EE-4083-ACAF-1C995657B473" name="Notify Priority SLA Updated" scriptFormat="http://www.java.com/java">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Notify Priority SLA Updated]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
