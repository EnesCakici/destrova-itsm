      <bpmn2:scriptTask id="_AC52F65A-3E25-4B29-BE91-D6D78FF8D45C" name="Force Closed" scriptFormat="http://www.java.com/java">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Force Closed]]></drools:metaValue>
