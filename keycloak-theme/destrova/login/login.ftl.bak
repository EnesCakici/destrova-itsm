<#import "template.ftl" as layout>
<@layout.registrationLayout displayMessage=!messagesPerField.existsError('username','password') displayInfo=realm.password && realm.registrationAllowed && !registrationDisabled??; section>

    <#if section = "header">
        <div class="destrova-form-header">
            <h2>Welcome back</h2>
            <p>Sign in to your account to continue.</p>
        </div>

    <#elseif section = "form">
        <#if realm.password>
            <form id="kc-form-login"
                  class="destrova-login-form"
                  onsubmit="login.disabled = true; return true;"
                  action="${url.loginAction}"
                  method="post">

                <#if !usernameHidden??>
                    <div class="destrova-field">
                        <label for="username">
                            <#if !realm.loginWithEmailAllowed>
                                ${msg("username")}
                            <#elseif !realm.registrationEmailAsUsername>
                                ${msg("usernameOrEmail")}
                            <#else>
                                ${msg("email")}
                            </#if>
                        </label>

                        <input
                            tabindex="1"
                            id="username"
                            name="username"
                            value="${(login.username!'')?xml}"
                            type="text"
                            autofocus
                            autocomplete="username"
                            aria-invalid="<#if messagesPerField.existsError('username','password')>true</#if>"
                        />

                        <#if messagesPerField.existsError('username','password')>
                            <div class="destrova-field-error" aria-live="polite">
                                ${kcSanitize(messagesPerField.getFirstError('username','password'))?no_esc}
                            </div>
                        </#if>
                    </div>
                </#if>

                <div class="destrova-field">
                    <label for="password">${msg("password")}</label>

                    <input
                        tabindex="2"
                        id="password"
                        name="password"
                        type="password"
                        autocomplete="current-password"
                        aria-invalid="<#if messagesPerField.existsError('username','password')>true</#if>"
                    />
                </div>

                <div class="destrova-options">
                    <#if realm.rememberMe && !usernameHidden??>
                        <label class="destrova-checkbox">
                            <input
                                tabindex="3"
                                id="rememberMe"
                                name="rememberMe"
                                type="checkbox"
                                <#if login.rememberMe??>checked</#if>
                            />
                            <span>${msg("rememberMe")}</span>
                        </label>
                    </#if>

                    <#if realm.resetPasswordAllowed>
                        <a tabindex="4" href="${url.loginResetCredentialsUrl}">
                            ${msg("doForgotPassword")}
                        </a>
                    </#if>
                </div>

                <button
                    tabindex="5"
                    class="destrova-submit"
                    name="login"
                    id="kc-login"
                    type="submit">
                    Sign in
                </button>
            </form>
        </#if>

    <#elseif section = "info">
        <#if realm.password && realm.registrationAllowed && !registrationDisabled??>
            <div id="kc-registration-container">
                <span>${msg("noAccount")} <a href="${url.registrationUrl}">${msg("doRegister")}</a></span>
            </div>
        </#if>
    </#if>
</@layout.registrationLayout>
